# Environment variables for YTS Movie Monitor
# Copy this to .env and customize

# Application Configuration
APP_VERSION=0.1.0

# Auto-update Configuration
# Update manifest URL (where signed manifest.json is hosted)
# Example: https://github.com/YOUR_USERNAME/YOUR_REPO/releases/latest/download/manifest.signed.json
UPDATE_MANIFEST_URL=

# HMAC key for verifying update manifest signatures (64-char hex)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# Must match MANIFEST_HMAC_KEY secret in GitHub Actions
MANIFEST_HMAC_KEY=

# YTS Website
YTS_BASE_URL=https://www.yts-official.top/browse-movies

# Scraping with curl_cffi (FREE!)
REQUEST_DELAY=2.0
REQUEST_TIMEOUT=15
MAX_RETRIES=3

# Poster Cache
MAX_CACHE_SIZE_MB=500

# Scraping Schedule
SCRAPE_INTERVAL_MINUTES=30

# Downloads
DOWNLOAD_PATH=E:\Downloads\Movies
MAX_CONCURRENT_DOWNLOADS=3

# Flask API
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=False

# Notifications
ENABLE_NOTIFICATIONS=True
